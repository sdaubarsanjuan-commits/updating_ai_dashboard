rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Insights matching
    match /insights/{insightId} {
      function isValidInsight(data) {
        return data.subject is string && data.subject.size() <= 1000 &&
               data.summary is string && data.summary.size() <= 4000 &&
               data.link is string && data.link.size() <= 2000 &&
               data.userId == request.auth.uid;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidInsight(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                      isValidInsight(incoming()) &&
                      incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // User scans matching
    match /user_scans/{userId} {
      function isValidScan(data) {
        return data.userId == userId &&
               data.status in ['idle', 'scanning', 'error'];
      }

      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidScan(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidScan(incoming());
    }
  }
}
